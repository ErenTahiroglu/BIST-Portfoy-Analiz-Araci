# Alpha Vantage API key (ücretsiz: https://www.alphavantage.co/support/#api-key)
# Bu dosyayı .env olarak kopyalayın ve key'inizi girin:
#   copy .env.example .env
ALPHA_VANTAGE_KEY=your_key_here

# Mock veri modu: True olarak ayarlandığında, internet kaynakları yerine
# mock_data/ klasöründeki CSV dosyalarını kullanır (çevrimdışı çalışma)
# Değerler: true, 1, yes → etkinleştir | diğer → kapalı
USE_MOCK_DATA=False
